# ==============================================================================
# MaxPayout Application Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' in the root folder, and/or load it into your shell before running.

# ------------------------------------------------------------------------------
# 1. Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL database connection string used by the 'api' server crate.
# Update with your local database username, password, host, and database name.
DATABASE_URL=postgresql://localhost/rfn_dev

# ------------------------------------------------------------------------------
# 2. Resend Email Delivery API (For Magic Links)
# ------------------------------------------------------------------------------
# Set this key to enable real email delivery via Resend.
# If blank, the system logs Magic Link URLs directly to the terminal stdout
# for zero-setup local developer testing.
# RESEND_API_KEY=re_your_secret_resend_api_key_here

# The sender address to send magic links from.
# If using a Resend onboarding/trial account, use onboarding@resend.dev.
# If using a verified domain, use your registered address (e.g., login@yourdomain.com).
RESEND_SENDER=onboarding@resend.dev

# ------------------------------------------------------------------------------
# 3. Local Development Toggles
# ------------------------------------------------------------------------------
# Set to 'true' to display mock magic links directly on the UI login screen.
# Perfect for lightning-fast testing without checking console output or email.
SHOW_LOCAL_TESTING_LINKS=true

# ------------------------------------------------------------------------------
# 4. WASI Storage Configuration
# ------------------------------------------------------------------------------
# Virtual folder used for WASI/Spin filesystem persistence.
# For local wasmtime/spin execution, this maps to the local directory `./data`.
STORAGE_PATH=/data
